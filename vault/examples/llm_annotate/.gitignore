# llm_annotate .gitignore
# 核心：core/ 目录跟踪，tools/ 目录忽略新增文件

# ========================================
# tools/ 目录 - 忽略新增文件
# ========================================
tools/*
!tools/__init__.py
!tools/stepflow_tag_tool.py
!tools/stepflow_compare_tool.py
!tools/templates/stepflow_tag.j2
!tools/templates/stepflow_compare.j2

# ========================================
# 根目录下的一次性脚本
# ========================================
run_*.py
test_*.py
demo_*.py
example_*.py
quick_*.py
temp_*.py
scratch_*.py

# ========================================
# 临时和输出文件
# ========================================
*.duckdb
*.sqlite
*.db
*.log
*.out
*.pkl
*.pth
*.jsonl
results/
outputs/
temp/
tmp/

# ========================================
# 配置文件 (可能包含敏感信息)
# ========================================
*.env
.env.*
!env.example

# ========================================
# Python 临时文件
# ========================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.pytest_cache/

# ========================================
# 编辑器和 IDE 文件
# ========================================
.vscode/
.idea/
*.swp
*.swo
*~

# ========================================
# 系统文件
# ========================================
.DS_Store
Thumbs.db